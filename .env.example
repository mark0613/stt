GOOGLE_API_KEY=your_api_key_here

# Gemini model settings
GEMINI_STT_MODEL=gemini-3.5-flash
GEMINI_MAX_OUTPUT_TOKENS=65536
GEMINI_THINKING_BUDGET=0
GEMINI_STT_TRANSIENT_RETRIES=3
GEMINI_STT_TRANSIENT_RETRY_DELAY_SECONDS=60

# Audio chunking
CHUNKED_SILENCE_NOISE_DB=-30
CHUNKED_SILENCE_MIN_DURATION=0.5
CHUNKED_TARGET_SECONDS=720
CHUNKED_MAX_SECONDS=1500

# STT pipeline
CHUNKED_TAIL_CONTEXT_SEGMENTS=5
CHUNKED_MAX_CONTINUATIONS=10
CHUNKED_PREMATURE_STOP_GAP=60
CHUNKED_PREMATURE_STOP_RETRIES=2
